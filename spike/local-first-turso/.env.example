# Copy to .env and fill from your Turso Developer-Plan account (see README).
# These are SPIKE-ONLY throwaway credentials — do not reuse app secrets.

# A platform/group API token used by the Node harness to MINT short-lived,
# DB-scoped sync tokens (simulates the future Better Auth /api/refresh-session
# endpoint). Get it from: turso auth token  (or a group token).
TURSO_PLATFORM_TOKEN=

# Org slug, used when minting DB-scoped tokens / building libsql URLs.
TURSO_ORG=

# A throwaway per-user data-plane DB provisioned for the round-trip/LWW spikes.
# e.g. libsql://spike-user-alice-<org>.turso.io
TURSO_DB_URL=

# A short-lived, DB-SCOPED auth token for TURSO_DB_URL (mint with a tight TTL,
# e.g. 30s, so 02-token-refresh can observe expiry + re-mint).
TURSO_DB_AUTH_TOKEN=
